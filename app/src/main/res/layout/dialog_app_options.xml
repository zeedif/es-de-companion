<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#252525">

    <!-- Launch Options -->
    <TextView
        android:id="@+id/btnLaunchThisScreen"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Launch on this screen"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true" />

    <TextView
        android:id="@+id/btnLaunchOtherScreen"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Launch on other screen"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/btnAppInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="App info"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:drawableStart="@android:drawable/ic_menu_info_details"
        android:drawablePadding="12dp"
        android:drawableTint="#FFFFFF"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true" />

    <TextView
        android:id="@+id/btnHideApp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Hide app"
        android:textColor="#CF6679"
        android:textSize="16sp"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:drawableStart="@android:drawable/ic_menu_view"
        android:drawablePadding="12dp"
        android:drawableTint="#CF6679"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true" />

</LinearLayout>